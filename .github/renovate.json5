{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  packageRules: [
    {
      groupName: 'Minor / patch version changes',
      groupSlug: 'minor-patch',
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
    },
    {
      groupName: 'github-actions',
      groupSlug: 'github-actions',
      matchManagers: [
        'github-actions',
      ],
      schedule: [
        '* * * * 1',
      ],
    },
    {
      groupName: 'docker-compose',
      groupSlug: 'docker-compose',
      matchManagers: [
        'docker-compose',
      ],
      schedule: [
        '* * * * 1',
      ],
    },
    {
      matchDatasources: [
        'custom.grafana-com-openapi',
      ],
      matchFileNames: [
        'openapi.json',
      ],
      automerge: true,
      branchPrefix: 'auto-merge/grafanarenovatebot/',
      versioning: 'loose',
    },
  ],
  customDatasources: {
    'grafana-com-openapi': {
      defaultRegistryUrlTemplate: 'https://grafana.com/api/openapi.json',
      format: 'json',
      transformTemplates: [
        '{"tags": {"latestVersion": $$.(info."x-generated-at")}, "releases":[{"version": $$.(info."x-generated-at"),"sourceUrl":"https://grafana.com/api/openapi.json","releaseTimestamp":$$.(info."x-generated-at"),"digest": $$.(info."x-commit-sha")}]}',
      ],
    },
  },
  customManagers: [
    {
      customType: 'regex',
      description: 'Update openapi.json file',
      managerFilePatterns: [
        '/^openapi.json$/',
      ],
      matchStrings: [
        '"(?<depName>x-generated-at)": "(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'custom.grafana-com-openapi',
    },
  ],
  postUpgradeTasks: {
    commands: [
      'curl https://grafana.com/api/openapi.json -o openapi.json',
    ],
  },
}
